# Copy to .env (`cp .env.example .env`) before `docker compose up`.
# docker compose reads this ONLY for ${VAR} interpolation in docker-compose.yml.
# (This file holds the Docker stack's secrets + URL/port config; `yarn dev` uses
# the per-package .env.*.local files instead and ignores this one.)

# --- Required: the fake IdP's signing keypair (the ONLY secret needed) ---------
# Generate a self-signed dev keypair:
#   openssl req -x509 -newkey rsa:2048 -keyout idp.key -out idp.crt -days 365 -nodes -subj "/CN=fake-idp"
# Then paste each as a SINGLE line with literal \n in place of newlines, e.g.:
#   awk 'NF{printf "%s\\n",$0}' idp.key   # private key body
#   awk 'NF{printf "%s\\n",$0}' idp.crt   # certificate body
# This one keypair covers both roles in the self-referential stack: the IdP signs
# assertions with it, and the SP both trusts the cert (idpCert) and signs its own
# AuthnRequests with it — so there is no separate SP keypair to configure.
SAML_IDP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
SAML_IDP_PUBLIC_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"

# --- Stack URL + host ports (switch domain and ports independently) -----------
# BASE_URL = protocol+host, NO port, NO trailing slash. The *_PORT values are the
# PUBLISHED host ports; containers always listen on 3000 internally. All the
# browser-facing SP/IdP URLs and the admin NEXT_PUBLIC_API_URL are composed from
# these in docker-compose.yml.
SAML_IDP_BASE_PATH=/myidp
BASE_URL=http://localhost
BACKEND_PORT=7000
ADMIN_PORT=7001
FRONTEND_PORT=7002
# CORS origins are derived from BASE_URL + ADMIN_PORT/FRONTEND_PORT. Set ORIGIN
# explicitly only to allow extra/multiple origins:
# ORIGIN=http://localhost:7001,http://localhost:7002

# --- Optional overrides (sensible defaults live in docker-compose.yml) --------
# Session secret (defaults to a dev value):
# SECRET_KEY=change-me
# Real WSO2 credentials, only needed if you exercise the upstream proxy APIs:
# CLIENT_KEY=...
# CLIENT_SECRET=...